{
  "name": "@vscode-use/createwebview",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.4",
  "description": "Small helper for creating VS Code webview panels with CSP and resource handling",
  "author": "Simon He",
  "license": "MIT",
  "funding": "https://github.com/sponsors/Simon-He95",
  "homepage": "https://github.com/vscode-use/createwebview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vscode-use/createwebview.git"
  },
  "bugs": "https://github.com/vscode-use/createwebview/issues",
  "keywords": [
    "vscode",
    "webview",
    "vscode-extension",
    "csp"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch src",
    "format": "prettier --write --cache .",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx,.md,.json --max-warnings 0 --cache",
    "lint:fix": "pnpm run lint --fix",
    "pack:check": "pnpm build && npm pack --dry-run",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "release": "bumpp && npm publish",
    "start": "esno src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.25.2",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.120.0",
    "bumpp": "^8.2.1",
    "eslint": "^8.18.0",
    "esno": "^0.16.3",
    "lint-staged": "^13.3.0",
    "picocolors": "^1.1.1",
    "prettier": "^2.8.8",
    "rimraf": "^3.0.2",
    "tsup": "^6.7.0",
    "tsx": "^3.14.0",
    "typescript": "^4.9.5",
    "vitest": "^0.15.2"
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ],
    "*.{vue,js,ts,jsx,tsx,md,json}": "eslint --fix"
  },
  "eslintConfig": {
    "extends": "@antfu"
  }
}
